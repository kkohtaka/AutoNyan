{
  "name": "autonyan-cloud-functions",
  "version": "1.0.0",
  "description": "Google Cloud Functions with TypeScript and Terraform",
  "scripts": {
    "build": "npm run build --workspaces",
    "build:function": "./scripts/build-function.sh",
    "validate:function": "./scripts/validate-function-packages.sh",
    "clean": "rm -rf dist/ && npm run clean --workspaces",
    "terraform:init": "terraform -chdir=terraform init -backend-config=environments/${ENVIRONMENT:-staging}.backend.hcl -reconfigure -upgrade -lock-timeout=5m",
    "terraform:apply": "npm run build:function && terraform -chdir=terraform apply -var-file=environments/${ENVIRONMENT:-staging}.tfvars -auto-approve -lock-timeout=5m",
    "terraform:plan": "npm run build:function && terraform -chdir=terraform plan -var-file=environments/${ENVIRONMENT:-staging}.tfvars -lock-timeout=5m",
    "terraform:destroy": "terraform -chdir=terraform destroy -var-file=environments/${ENVIRONMENT:-staging}.tfvars -auto-approve",
    "terraform:validate": "npm run terraform:init && terraform -chdir=terraform validate",
    "deploy": "timeout 600 npm run terraform:apply",
    "test": "npm run test --workspaces",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "test:e2e": "tsx tests/e2e/scripts/test-drive-access.ts && NODE_OPTIONS='--experimental-vm-modules' ENVIRONMENT=staging jest --config=tests/e2e/jest.config.e2e.js --runInBand",
    "test:e2e:check-auth": "tsx tests/e2e/scripts/check-auth.ts",
    "test:e2e:check-drive": "tsx tests/e2e/scripts/test-drive-access.ts",
    "test:e2e:cleanup": "tsx tests/e2e/scripts/cleanup-orphaned-resources.ts",
    "lint": "npm run lint:ts && npm run lint:yaml && npm run lint:json && npm run lint:terraform && npm run lint:sh",
    "lint:ts": "npm run lint --workspaces",
    "lint:yaml": "yamllint .github/ -c .yamllint.yml",
    "lint:json": "eslint '**/*.json' --fix",
    "lint:terraform": "terraform fmt -check=true -recursive terraform/ && tflint --chdir=terraform/",
    "lint:sh": "shellcheck scripts/*.sh",
    "format": "npm run format:ts && npm run format:yaml && npm run format:json && npm run format:terraform && npm run format:sh",
    "format:ts": "npm run format --workspaces",
    "format:yaml": "prettier --write '.github/**/*.{yml,yaml}'",
    "format:json": "prettier --write '**/*.json'",
    "format:terraform": "terraform fmt -recursive terraform/",
    "format:sh": "shfmt -w scripts/*.sh",
    "prepare": "./scripts/setup-git-hooks.sh",
    "setup:git-hooks": "./scripts/setup-git-hooks.sh",
    "setup:terraform-backend": "./scripts/setup-backend.sh",
    "setup:terraform-variables": "./scripts/setup-terraform-variables.sh",
    "setup:github-actions": "./scripts/setup-github-actions.sh",
    "setup:share-drive-folders": "tsx scripts/share-drive-folders.ts"
  },
  "workspaces": [
    "src/functions/*",
    "src/shared"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@google/events": "^5.4.0",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsonc": "^3.0.0",
    "jest": "^30.2.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
