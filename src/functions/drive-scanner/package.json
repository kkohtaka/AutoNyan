{
  "name": "drive-scanner-function",
  "version": "1.0.0",
  "description": "Google Drive document scanner Cloud Function",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "clean": "rm -f *.js *.js.map *.d.ts && rm -rf dist/",
    "test": "jest --config=../../../jest.config.js --testPathPatterns=drive-scanner --logHeapUsage",
    "test:coverage": "cd ../../.. && jest --config=jest.config.js --coverage --testPathPatterns=drive-scanner --collectCoverageFrom='src/functions/drive-scanner/**/*.{ts,tsx}' --collectCoverageFrom='!src/functions/drive-scanner/**/*.test.{ts,tsx}' --collectCoverageFrom='!src/functions/drive-scanner/**/*.spec.{ts,tsx}' --logHeapUsage",
    "lint": "eslint --config=../../../eslint.config.js --fix",
    "format": "prettier --write '**/*.ts'"
  },
  "engines": {
    "node": "24.18.0"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.5.0",
    "@google-cloud/functions-framework": "^5.0.2",
    "@google-cloud/pubsub": "^5.3.0",
    "googleapis": "^173.0.0",
    "@google/events": "^5.4.0",
    "autonyan-shared": "file:../../shared"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.0"
  }
}
