{
  "name": "notification-dispatcher",
  "version": "1.0.0",
  "description": "Cloud Function for dispatching notifications on document processing success and failure",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "clean": "rm -f *.js *.js.map *.d.ts && rm -rf dist/",
    "test": "jest --config=../../../jest.config.js --testPathPatterns=notification-dispatcher --logHeapUsage",
    "test:coverage": "cd ../../.. && jest --config=jest.config.js --coverage --testPathPatterns=notification-dispatcher --collectCoverageFrom='src/functions/notification-dispatcher/index.ts' --logHeapUsage",
    "lint": "eslint --config=../../../eslint.config.js --fix",
    "format": "prettier --write '**/*.ts'"
  },
  "dependencies": {
    "@google-cloud/functions-framework": "^5.0.0",
    "@google/events": "^5.4.0",
    "googleapis": "^173.0.0",
    "autonyan-shared": "file:../../shared"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.15.0"
  }
}
