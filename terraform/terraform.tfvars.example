# Copy this file to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to version control - it contains sensitive data

project_id = "your-project-id"
region = "us-central1"
drive_folder_id = "your-google-drive-folder-id"
drive_scanner_schedule = "0 * * * *"

# File classification configuration
# category_root_folder_id: Google Drive folder containing category subfolders (e.g., "請求書", "契約書")
# uncategorized_folder_id: Google Drive folder for files that don't match any category
category_root_folder_id = "your-category-root-folder-id"
uncategorized_folder_id = "your-uncategorized-folder-id"

# Cost guardrail configuration
# billing_account_id: Cloud Billing account ID in the form XXXXXX-XXXXXX-XXXXXX
# budget_amount: monthly budget in whole units of budget_currency_code
# budget_currency_code / budget_alert_thresholds are optional (defaults: "USD", [0.5, 0.9, 1.0])
billing_account_id = "XXXXXX-XXXXXX-XXXXXX"
budget_amount = 50
# budget_currency_code = "USD"
# budget_alert_thresholds = [0.5, 0.9, 1.0]
